<section class="grim-arithmetic-panel grim-arithmetic-forecast">
  <header class="grim-arithmetic-panel__header">
    <h2>Encounter Forecast</h2>
    <p class="grim-arithmetic-panel__tagline">Monte Carlo simulation of the active encounter under explicit assumptions.</p>
  </header>

  {{#unless enabled}}
    <p class="grim-arithmetic-forecast__disabled">{{disabledMessage}}</p>
  {{else}}
    <p class="grim-arithmetic-panel__hint">{{message}}</p>

    <form class="grim-arithmetic-forecast__controls">
      <label>
        Tactics profile
        <select data-grim-forecast-control="tacticsProfile" {{#if (eq state "running")}}disabled{{/if}}>
          {{#each controls.tacticsProfile}}
            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>

      <div class="grim-arithmetic-forecast__buttons">
        <button type="button" data-action="run" {{#if (eq state "running")}}disabled{{/if}}>Forecast</button>
        <button type="button" data-action="cancel" {{#unless (eq state "running")}}disabled{{/unless}}>Cancel</button>
      </div>
    </form>

    {{#if (eq state "running")}}
      <section class="grim-arithmetic-forecast__progress">
        <p>Running iteration {{progress.completed}} of {{progress.total}} ({{progress.percent}}%)…</p>
      </section>
    {{/if}}

    {{#if (eq state "error")}}
      <section class="grim-arithmetic-forecast__error">
        <h3>Forecast failed</h3>
        <p>{{errorMessage}}</p>
      </section>
    {{/if}}

    {{#if (eq state "done")}}
      {{#if pessimismWarning}}
        <section class="grim-arithmetic-forecast__pessimism-banner">
          <strong>High-risk encounter.</strong>
          {{pessimismWarning}}
        </section>
      {{/if}}
      <section class="grim-arithmetic-forecast__result">
        <p class="grim-arithmetic-forecast__profile">
          <strong>{{result.tacticsProfileLabel}}</strong> — {{result.tacticsProfileDescription}}
        </p>
        <div class="grim-arithmetic-forecast__headline">
          <div class="grim-arithmetic-forecast__metric">
            <span class="grim-arithmetic-forecast__metric-label">Any PC down</span>
            <span class="grim-arithmetic-forecast__metric-value">{{result.anyPcDownPercent}}%</span>
            {{#if result.anyPcDownCi}}<span class="grim-arithmetic-forecast__ci">[{{result.anyPcDownCi}}]</span>{{/if}}
          </div>
          <div class="grim-arithmetic-forecast__metric">
            <span class="grim-arithmetic-forecast__metric-label">TPK risk</span>
            <span class="grim-arithmetic-forecast__metric-value">{{result.tpkPercent}}%</span>
            {{#if result.tpkCi}}<span class="grim-arithmetic-forecast__ci">[{{result.tpkCi}}]</span>{{/if}}
          </div>
          <div class="grim-arithmetic-forecast__metric">
            <span class="grim-arithmetic-forecast__metric-label">Expected first down</span>
            <span class="grim-arithmetic-forecast__metric-value">round {{result.meanFirstDownRound}}</span>
            {{#if result.meanFirstDownCi}}<span class="grim-arithmetic-forecast__ci">[{{result.meanFirstDownCi}}]</span>{{/if}}
          </div>
        </div>

        <div class="grim-arithmetic-forecast__headline grim-arithmetic-forecast__safety-net">
          <div class="grim-arithmetic-forecast__metric">
            <span class="grim-arithmetic-forecast__metric-label">Heals per run</span>
            <span class="grim-arithmetic-forecast__metric-value">{{result.meanHealsPerIteration}}</span>
          </div>
          <div class="grim-arithmetic-forecast__metric">
            <span class="grim-arithmetic-forecast__metric-label">Recovery checks per run</span>
            <span class="grim-arithmetic-forecast__metric-value">{{result.meanRecoveryChecksPerIteration}}</span>
          </div>
          <div class="grim-arithmetic-forecast__metric">
            <span class="grim-arithmetic-forecast__metric-label">Hero Point saves</span>
            <span class="grim-arithmetic-forecast__metric-value">{{result.heroPointSurvivalPercent}}%</span>
          </div>
        </div>

        <p class="grim-arithmetic-forecast__run-meta">
          {{result.tacticsProfileLabel}}
          {{#if result.aborted}} · <strong>aborted</strong>{{/if}}
        </p>
        {{#if result.anyPcDownCi}}
          <p class="grim-arithmetic-forecast__ci-note">Bracketed values are 95% confidence intervals from sampling variance.</p>
        {{/if}}

        <h3>Most likely to drop</h3>
        <table class="grim-arithmetic-forecast__table">
          <thead>
            <tr>
              <th>PC</th>
              <th>Down</th>
              <th>Death</th>
              <th>Expected HP</th>
              <th>Biggest threat</th>
              <th>Risk</th>
            </tr>
          </thead>
          <tbody>
            {{#each result.perPc}}
              <tr>
                <td>{{name}}</td>
                <td>{{downPercent}}%{{#if downCi}} <span class="grim-arithmetic-forecast__ci">[{{downCi}}]</span>{{/if}}</td>
                <td>{{deathPercent}}%{{#if deathCi}} <span class="grim-arithmetic-forecast__ci">[{{deathCi}}]</span>{{/if}}</td>
                <td>{{meanEndingHp}}</td>
                <td>{{topContributingEnemyName}}</td>
                <td><span class="grim-arithmetic-panel__risk-pill grim-arithmetic-panel__risk-pill--{{riskClass}}">{{riskLabel}}</span></td>
              </tr>
            {{/each}}
          </tbody>
        </table>

        <h3>Biggest threats</h3>
        <table class="grim-arithmetic-forecast__table">
          <thead>
            <tr>
              <th>Enemy</th>
              <th>Damage share</th>
              <th>Top target</th>
            </tr>
          </thead>
          <tbody>
            {{#each result.perEnemy}}
              <tr>
                <td>{{name}}</td>
                <td>{{damageSharePercent}}%</td>
                <td>{{topTargetName}}</td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </section>
    {{/if}}

    <section class="grim-arithmetic-forecast__assumptions">
      <h3>Modeled assumptions</h3>
      <ul>
        {{#each assumptions}}
          <li>{{this}}</li>
        {{/each}}
      </ul>
    </section>
  {{/unless}}
</section>
