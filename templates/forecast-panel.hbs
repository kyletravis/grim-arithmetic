<section class="grim-arithmetic-panel grim-arithmetic-forecast">
  <header class="grim-arithmetic-panel__header">
    <h2>{{localize "GrimArithmetic.Forecast.Heading"}}</h2>
    <p class="grim-arithmetic-panel__tagline">{{localize "GrimArithmetic.Forecast.Tagline"}}</p>
  </header>

  {{#unless enabled}}
    <p class="grim-arithmetic-forecast__disabled">{{disabledMessage}}</p>
  {{else}}
    <p class="grim-arithmetic-panel__hint">{{message}}</p>

    <form class="grim-arithmetic-forecast__controls">
      <label>
        <span data-tooltip="{{localize "GrimArithmetic.Forecast.TacticsTooltip"}}">{{localize "GrimArithmetic.Forecast.TacticsLabel"}}</span>
        <ul class="grim-arithmetic-forecast__tactics-defs">
          {{#each controls.tacticsProfile}}
            <li><strong>{{label}}:</strong> {{description}}</li>
          {{/each}}
        </ul>
        <select data-grim-forecast-control="tacticsProfile" {{#if (eq state "running")}}disabled{{/if}}>
          {{#each controls.tacticsProfile}}
            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>

      <div class="grim-arithmetic-forecast__buttons">
        <button type="button" data-action="run" {{#if (eq state "running")}}disabled{{/if}}>{{localize "GrimArithmetic.Forecast.RunButton"}}</button>
        <button type="button" data-action="cancel" {{#unless (eq state "running")}}disabled{{/unless}}>{{localize "GrimArithmetic.Forecast.CancelButton"}}</button>
      </div>
    </form>

    {{#if (eq state "running")}}
      <section class="grim-arithmetic-forecast__progress">
        <p>{{localize "GrimArithmetic.Forecast.Progress" completed=progress.completed total=progress.total percent=progress.percent}}</p>
      </section>
    {{/if}}

    {{#if (eq state "error")}}
      <section class="grim-arithmetic-forecast__error">
        <h3>{{localize "GrimArithmetic.Forecast.FailedHeading"}}</h3>
        <p>{{errorMessage}}</p>
      </section>
    {{/if}}

    {{#if (eq state "done")}}
      {{#if pessimismWarning}}
        <section class="grim-arithmetic-forecast__pessimism-banner">
          <strong>{{localize "GrimArithmetic.Forecast.PessimismLead"}}</strong>
          {{pessimismWarning}}
        </section>
      {{/if}}
      <section class="grim-arithmetic-forecast__result">
        <p class="grim-arithmetic-forecast__profile">
          <strong>{{result.tacticsProfileLabel}}</strong> — {{result.tacticsProfileDescription}}
        </p>
        <div class="grim-arithmetic-forecast__headline">
          <div class="grim-arithmetic-forecast__metric">
            <span class="grim-arithmetic-forecast__metric-label" data-tooltip="{{localize "GrimArithmetic.Forecast.AnyPcDownTooltip"}}">{{localize "GrimArithmetic.Forecast.AnyPcDownLabel"}}</span>
            <span class="grim-arithmetic-forecast__metric-value">{{result.anyPcDownPercent}}%</span>
            {{#if result.anyPcDownCi}}<span class="grim-arithmetic-forecast__ci" data-tooltip="{{localize "GrimArithmetic.Common.CiTooltip"}}">[{{result.anyPcDownCi}}]</span>{{/if}}
          </div>
          <div class="grim-arithmetic-forecast__metric">
            <span class="grim-arithmetic-forecast__metric-label" data-tooltip="{{localize "GrimArithmetic.Forecast.TpkTooltip"}}">{{localize "GrimArithmetic.Forecast.TpkLabel"}}</span>
            <span class="grim-arithmetic-forecast__metric-value">{{result.tpkPercent}}%</span>
            {{#if result.tpkCi}}<span class="grim-arithmetic-forecast__ci" data-tooltip="{{localize "GrimArithmetic.Common.CiTooltip"}}">[{{result.tpkCi}}]</span>{{/if}}
          </div>
          <div class="grim-arithmetic-forecast__metric">
            <span class="grim-arithmetic-forecast__metric-label" data-tooltip="{{localize "GrimArithmetic.Forecast.FirstDownTooltip"}}">{{localize "GrimArithmetic.Forecast.FirstDownLabel"}}</span>
            <span class="grim-arithmetic-forecast__metric-value">{{localize "GrimArithmetic.Forecast.RoundPrefix"}} {{result.meanFirstDownRound}}</span>
            {{#if result.meanFirstDownCi}}<span class="grim-arithmetic-forecast__ci" data-tooltip="{{localize "GrimArithmetic.Common.CiTooltip"}}">[{{result.meanFirstDownCi}}]</span>{{/if}}
          </div>
        </div>

        <div class="grim-arithmetic-forecast__headline grim-arithmetic-forecast__safety-net">
          <div class="grim-arithmetic-forecast__metric">
            <span class="grim-arithmetic-forecast__metric-label" data-tooltip="{{localize "GrimArithmetic.Forecast.HealsTooltip"}}">{{localize "GrimArithmetic.Forecast.HealsLabel"}}</span>
            <span class="grim-arithmetic-forecast__metric-value">{{result.meanHealsPerIteration}}</span>
          </div>
          <div class="grim-arithmetic-forecast__metric">
            <span class="grim-arithmetic-forecast__metric-label" data-tooltip="{{localize "GrimArithmetic.Forecast.RecoveryTooltip"}}">{{localize "GrimArithmetic.Forecast.RecoveryLabel"}}</span>
            <span class="grim-arithmetic-forecast__metric-value">{{result.meanRecoveryChecksPerIteration}}</span>
          </div>
          <div class="grim-arithmetic-forecast__metric">
            <span class="grim-arithmetic-forecast__metric-label" data-tooltip="{{localize "GrimArithmetic.Forecast.HeroPointTooltip"}}">{{localize "GrimArithmetic.Forecast.HeroPointLabel"}}</span>
            <span class="grim-arithmetic-forecast__metric-value">{{result.heroPointSurvivalPercent}}%</span>
          </div>
        </div>

        <p class="grim-arithmetic-forecast__run-meta">
          {{result.tacticsProfileLabel}}
          {{#if result.aborted}} · <strong>{{localize "GrimArithmetic.Forecast.Aborted"}}</strong>{{/if}}
        </p>
        {{#if result.anyPcDownCi}}
          <p class="grim-arithmetic-forecast__ci-note">{{localize "GrimArithmetic.Forecast.CiNote"}}</p>
        {{/if}}

        <h3>{{localize "GrimArithmetic.Forecast.MostLikelyToDrop"}}</h3>
        <table class="grim-arithmetic-forecast__table">
          <thead>
            <tr>
              <th>{{localize "GrimArithmetic.Forecast.Table.Pc"}}</th>
              <th data-tooltip="{{localize "GrimArithmetic.Forecast.Table.DownTooltip"}}">{{localize "GrimArithmetic.Forecast.Table.Down"}}</th>
              <th data-tooltip="{{localize "GrimArithmetic.Forecast.Table.DeathTooltip"}}">{{localize "GrimArithmetic.Forecast.Table.Death"}}</th>
              <th data-tooltip="{{localize "GrimArithmetic.Forecast.Table.ExpectedHpTooltip"}}">{{localize "GrimArithmetic.Forecast.Table.ExpectedHp"}}</th>
              <th data-tooltip="{{localize "GrimArithmetic.Forecast.Table.BiggestThreatTooltip"}}">{{localize "GrimArithmetic.Forecast.Table.BiggestThreat"}}</th>
              <th data-tooltip="{{localize "GrimArithmetic.Forecast.Table.RiskTooltip"}}">{{localize "GrimArithmetic.Forecast.Table.Risk"}}</th>
            </tr>
          </thead>
          <tbody>
            {{#each result.perPc}}
              <tr>
                <td>{{name}}</td>
                <td>{{downPercent}}%{{#if downCi}} <span class="grim-arithmetic-forecast__ci" data-tooltip="{{localize "GrimArithmetic.Common.CiTooltip"}}">[{{downCi}}]</span>{{/if}}</td>
                <td>{{deathPercent}}%{{#if deathCi}} <span class="grim-arithmetic-forecast__ci" data-tooltip="{{localize "GrimArithmetic.Common.CiTooltip"}}">[{{deathCi}}]</span>{{/if}}</td>
                <td>{{meanEndingHp}}</td>
                <td>{{topContributingEnemyName}}</td>
                <td><span class="grim-arithmetic-panel__risk-pill grim-arithmetic-panel__risk-pill--{{riskClass}}" data-tooltip="{{localize "GrimArithmetic.Common.RiskPillTooltip"}}">{{riskLabel}}</span></td>
              </tr>
            {{/each}}
          </tbody>
        </table>

        <h3>{{localize "GrimArithmetic.Forecast.BiggestThreats"}}</h3>
        <table class="grim-arithmetic-forecast__table">
          <thead>
            <tr>
              <th>{{localize "GrimArithmetic.Forecast.Table.Enemy"}}</th>
              <th data-tooltip="{{localize "GrimArithmetic.Forecast.Table.DamageShareTooltip"}}">{{localize "GrimArithmetic.Forecast.Table.DamageShare"}}</th>
              <th data-tooltip="{{localize "GrimArithmetic.Forecast.Table.TopTargetTooltip"}}">{{localize "GrimArithmetic.Forecast.Table.TopTarget"}}</th>
            </tr>
          </thead>
          <tbody>
            {{#each result.perEnemy}}
              <tr>
                <td>{{name}}</td>
                <td>{{damageSharePercent}}%</td>
                <td>{{topTargetName}}</td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </section>
    {{/if}}

    <section class="grim-arithmetic-forecast__assumptions">
      <h3>{{localize "GrimArithmetic.Forecast.ModeledAssumptions"}}</h3>
      <ul>
        {{#each assumptions}}
          <li>{{this}}</li>
        {{/each}}
      </ul>
    </section>
  {{/unless}}
</section>
