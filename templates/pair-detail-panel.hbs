<section class="grim-arithmetic-panel">
  <header class="grim-arithmetic-panel__header">
    <h2>{{localize "GrimArithmetic.PairDetail.Heading"}}</h2>
    <p class="grim-arithmetic-panel__tagline">{{localize "GrimArithmetic.PairDetail.Tagline"}}</p>
  </header>

  <p>{{message}}</p>

  <form class="grim-arithmetic-panel__controls">
    <label>
      <span data-tooltip="{{localize "GrimArithmetic.PairDetail.EnemyStrikeTooltip"}}">{{localize "GrimArithmetic.PairDetail.EnemyStrikeLabel"}}</span>
      <select data-grim-control="attackId" {{#unless controls.attacks.length}}disabled{{/unless}}>
        {{#each controls.attacks}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
        {{/each}}
      </select>
    </label>

    <label>
      <span data-tooltip="{{localize "GrimArithmetic.PairDetail.EnemyTurnTooltip"}}">{{localize "GrimArithmetic.PairDetail.EnemyTurnLabel"}}</span>
      <select data-grim-control="strikes">
        {{#each controls.strikes}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
        {{/each}}
      </select>
    </label>

    <label>
      <span data-tooltip="{{localize "GrimArithmetic.PairDetail.MapTooltip"}}">{{localize "GrimArithmetic.PairDetail.MapLabel"}}</span>
      <select data-grim-control="mapMode">
        {{#each controls.mapMode}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
        {{/each}}
      </select>
    </label>

    <label>
      <span data-tooltip="{{localize "GrimArithmetic.PairDetail.ShieldTooltip"}}">{{localize "GrimArithmetic.PairDetail.ShieldLabel"}}</span>
      <select data-grim-control="shieldBonus">
        {{#each controls.shieldBonus}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
        {{/each}}
      </select>
    </label>

    <label>
      <span data-tooltip="{{localize "GrimArithmetic.PairDetail.WoundedTooltip"}}">{{localize "GrimArithmetic.PairDetail.WoundedLabel"}}</span>
      <select data-grim-control="woundedOverride">
        {{#each controls.woundedOverride}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
        {{/each}}
      </select>
    </label>

    <label>
      <span data-tooltip="{{localize "GrimArithmetic.PairDetail.HeroPointTooltip"}}">{{localize "GrimArithmetic.PairDetail.HeroPointLabel"}}</span>
      <select data-grim-control="heroPointMode">
        {{#each controls.heroPointMode}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
        {{/each}}
      </select>
    </label>

    <button type="button" class="grim-arithmetic-panel__refresh" data-action="refresh">{{localize "GrimArithmetic.PairDetail.RefreshButton"}}</button>
  </form>

  {{#if errors.length}}
    <div class="grim-arithmetic-panel__errors">
      <h3>{{localize "GrimArithmetic.PairDetail.NeedsAttention"}}</h3>
      <ul>
        {{#each errors}}
          <li>{{this}}</li>
        {{/each}}
      </ul>
    </div>
  {{/if}}

  {{#if risk}}
    <section class="grim-arithmetic-panel__summary">
      <h3>{{subject.name}} {{localize "GrimArithmetic.Common.Vs"}} {{enemy.name}}</h3>
      <dl>
        <dt data-tooltip="{{localize "GrimArithmetic.PairDetail.EnemyStrikeTermTooltip"}}">{{localize "GrimArithmetic.PairDetail.EnemyStrikeLabel"}}</dt>
        <dd>{{localize "GrimArithmetic.PairDetail.EnemyStrikeValue" name=attack.name bonus=attack.attackBonus formula=attack.damageFormula}}</dd>

        <dt data-tooltip="{{localize "GrimArithmetic.PairDetail.ModeledHpTooltip"}}">{{localize "GrimArithmetic.PairDetail.ModeledHp"}}</dt>
        <dd>{{risk.modeledHp}}</dd>

        <dt data-tooltip="{{localize "GrimArithmetic.PairDetail.EffectiveAcTooltip"}}">{{localize "GrimArithmetic.PairDetail.EffectiveAc"}}</dt>
        <dd>{{risk.effectiveAc}}</dd>

        <dt data-tooltip="{{localize "GrimArithmetic.PairDetail.WoundedTermTooltip"}}">{{localize "GrimArithmetic.PairDetail.Wounded"}}</dt>
        <dd>{{risk.woundedNote}}</dd>

        <dt data-tooltip="{{localize "GrimArithmetic.PairDetail.DamageRangeTooltip"}}">{{localize "GrimArithmetic.PairDetail.DamageRange"}}</dt>
        <dd>{{localize "GrimArithmetic.PairDetail.DamageRangeValue" min=risk.damage.min max=risk.damage.max critMin=risk.damage.critMin critMax=risk.damage.critMax}}</dd>

        <dt data-tooltip="{{localize "GrimArithmetic.PairDetail.AverageDamageTooltip"}}">{{localize "GrimArithmetic.PairDetail.AverageDamage"}}</dt>
        <dd>{{risk.damage.average}}</dd>

        <dt data-tooltip="{{localize "GrimArithmetic.PairDetail.DamageSwingTooltip"}}">{{localize "GrimArithmetic.PairDetail.DamageSwing"}}</dt>
        <dd>{{risk.damage.swinginess}}</dd>

        <dt data-tooltip="{{localize "GrimArithmetic.PairDetail.DamageAdjustmentTooltip"}}">{{localize "GrimArithmetic.PairDetail.DamageAdjustment"}}</dt>
        <dd>{{risk.damageAdjustment.note}}</dd>

        <dt data-tooltip="{{localize "GrimArithmetic.PairDetail.DownChanceTooltip"}}">{{localize "GrimArithmetic.PairDetail.DownChance"}}</dt>
        <dd><strong>{{risk.downPercent}}%</strong> — {{risk.riskLabel}}</dd>

        <dt data-tooltip="{{localize "GrimArithmetic.PairDetail.ExpectedHpAfterTurnTooltip"}}">{{localize "GrimArithmetic.PairDetail.ExpectedHpAfterTurn"}}</dt>
        <dd>{{risk.expectedHpAfterTurn}}</dd>

        <dt data-tooltip="{{localize "GrimArithmetic.PairDetail.DyingIfDownedTooltip"}}">{{localize "GrimArithmetic.PairDetail.DyingIfDowned"}}</dt>
        <dd>{{localize "GrimArithmetic.PairDetail.DyingIfDownedValue" normal=risk.dyingSeverity.normalDownDying crit=risk.dyingSeverity.critDownDying}}</dd>

        <dt data-tooltip="{{localize "GrimArithmetic.PairDetail.DeathThresholdTooltip"}}">{{localize "GrimArithmetic.PairDetail.DeathThreshold"}}</dt>
        <dd>{{localize "GrimArithmetic.PairDetail.DeathThresholdValue" threshold=risk.dyingSeverity.deathThreshold doomed=risk.dyingSeverity.doomed}}</dd>

        <dt data-tooltip="{{localize "GrimArithmetic.PairDetail.ImmediateDeathFlagTooltip"}}">{{localize "GrimArithmetic.PairDetail.ImmediateDeathFlag"}}</dt>
        <dd>{{risk.dyingSeverity.immediateDeathFlag}}</dd>

        <dt data-tooltip="{{localize "GrimArithmetic.PairDetail.HeroPointNoteTooltip"}}">{{localize "GrimArithmetic.PairDetail.HeroPointNote"}}</dt>
        <dd>{{risk.dyingSeverity.heroPointNote}}</dd>
      </dl>
    </section>

    <section class="grim-arithmetic-panel__strikes">
      <h3>{{localize "GrimArithmetic.PairDetail.StrikeChances"}}</h3>
      <ol>
        {{#each risk.strikeChances}}
          <li>{{localize "GrimArithmetic.PairDetail.StrikeLine" index=index hit=hitPercent crit=critPercent}}</li>
        {{/each}}
      </ol>
    </section>

    <section class="grim-arithmetic-panel__details">
      <details class="grim-arithmetic-details">
        <summary>{{localize "GrimArithmetic.PairDetail.AssumptionsSummary"}}</summary>

        <h3>{{localize "GrimArithmetic.PairDetail.Assumptions"}}</h3>
        <ul>
          {{#each risk.assumptions}}
            <li>{{this}}</li>
          {{/each}}
        </ul>

        <h3>{{localize "GrimArithmetic.PairDetail.NotModeledYet"}}</h3>
        <ul>
          {{#each risk.notModeled}}
            <li>{{this}}</li>
          {{/each}}
        </ul>
      </details>
    </section>
  {{/if}}
</section>
