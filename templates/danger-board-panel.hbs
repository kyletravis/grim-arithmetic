<section class="grim-arithmetic-panel">
  <header class="grim-arithmetic-panel__header">
    <h2>Grim Arithmetic v{{moduleVersion}}</h2>
    <p class="grim-arithmetic-panel__tagline">Encounter danger board — immediate mortality pressure, not fate.</p>
  </header>

  <p class="grim-arithmetic-panel__hint">{{message}}</p>

  <div class="grim-arithmetic-panel__board-actions">
    {{#if forecastEnabled}}
      <button type="button" data-action="openForecast" data-tooltip="Run a Monte Carlo simulation of the whole encounter to forecast downs, deaths, and TPK risk.">Encounter Forecast</button>
    {{/if}}
    <button type="button" data-action="openDetailSelection" data-tooltip="Open a detailed one-attacker-vs-one-PC mortality breakdown for the selected token and target.">Detail Selection + Target</button>
    <button type="button" data-action="refresh" data-tooltip="Recompute the danger board from the current combat state.">Refresh</button>
  </div>

  <section class="grim-arithmetic-panel__danger-board">
    {{#if dangerBoard.skipped}}
      <p class="grim-arithmetic-panel__danger-board-empty">
        Encounter too large to compute a danger board safely. Reduce combatants, or use the selection + target button above for a single-pair view.
      </p>
    {{else if dangerBoard.empty}}
      <p class="grim-arithmetic-panel__danger-board-empty">
        No encounter-wide risk to show. Start a combat with PCs and hostile NPCs, or use the selection + target button above.
      </p>
    {{else}}
      <h3 class="grim-arithmetic-panel__section-title" data-tooltip="PCs ranked by their single-round chance of being knocked out by the most dangerous incoming attack.">Most endangered PCs</h3>
      <ol class="grim-arithmetic-panel__danger-grid">
        {{#each dangerBoard.topEndangeredPcs}}
          <li class="grim-arithmetic-panel__danger-row">
            <span class="grim-arithmetic-panel__danger-row-rank" aria-hidden="true"></span>
            <span class="grim-arithmetic-panel__danger-row-label">
              <strong>{{pcName}}</strong>
              <span class="grim-arithmetic-panel__danger-row-vs">vs</span>
              {{enemyName}} <em>{{attackName}}</em>
            </span>
            <span class="grim-arithmetic-panel__danger-row-percent" data-tooltip="Chance this PC is knocked out in one round by this attack.">{{downPercent}}%</span>
            <span class="grim-arithmetic-panel__risk-pill grim-arithmetic-panel__risk-pill--{{riskClass}}" data-tooltip="Risk rating from chance of being downed: Low → Grim.">{{riskLabel}}</span>
            <button type="button"
                    class="grim-arithmetic-panel__danger-row-action"
                    data-action="openDetailPair"
                    data-grim-pc-id="{{pcId}}"
                    data-grim-enemy-id="{{enemyId}}"
                    data-grim-attack-id="{{attackId}}">Detail</button>
          </li>
        {{/each}}
      </ol>

      <h3 class="grim-arithmetic-panel__section-title" data-tooltip="Enemy attacks ranked by their single-round chance of knocking out a PC.">Most dangerous enemies</h3>
      <ol class="grim-arithmetic-panel__danger-grid">
        {{#each dangerBoard.topDangerousEnemies}}
          <li class="grim-arithmetic-panel__danger-row">
            <span class="grim-arithmetic-panel__danger-row-rank" aria-hidden="true"></span>
            <span class="grim-arithmetic-panel__danger-row-label">
              <strong>{{enemyName}}</strong> <em>{{attackName}}</em>
              <span class="grim-arithmetic-panel__danger-row-vs">vs</span>
              {{pcName}}
            </span>
            <span class="grim-arithmetic-panel__danger-row-percent" data-tooltip="Chance this PC is knocked out in one round by this attack.">{{downPercent}}%</span>
            <span class="grim-arithmetic-panel__risk-pill grim-arithmetic-panel__risk-pill--{{riskClass}}" data-tooltip="Risk rating from chance of being downed: Low → Grim.">{{riskLabel}}</span>
            <button type="button"
                    class="grim-arithmetic-panel__danger-row-action"
                    data-action="openDetailPair"
                    data-grim-pc-id="{{pcId}}"
                    data-grim-enemy-id="{{enemyId}}"
                    data-grim-attack-id="{{attackId}}">Detail</button>
          </li>
        {{/each}}
      </ol>
    {{/if}}

    {{#if dangerBoard.caveats.length}}
      <ul class="grim-arithmetic-panel__danger-caveats">
        {{#each dangerBoard.caveats}}
          <li>{{this}}</li>
        {{/each}}
      </ul>
    {{/if}}
  </section>
</section>
