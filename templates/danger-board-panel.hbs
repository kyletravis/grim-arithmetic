<section class="grim-arithmetic-panel">
  <header class="grim-arithmetic-panel__header">
    <h2>{{localize "GrimArithmetic.DangerBoard.Heading" version=moduleVersion}}</h2>
    <p class="grim-arithmetic-panel__tagline">{{localize "GrimArithmetic.DangerBoard.Tagline"}}</p>
  </header>

  <p class="grim-arithmetic-panel__hint">{{message}}</p>

  <div class="grim-arithmetic-panel__board-actions">
    {{#if forecastEnabled}}
      <button type="button" data-action="openForecast" data-tooltip="{{localize "GrimArithmetic.DangerBoard.ForecastTooltip"}}">{{localize "GrimArithmetic.DangerBoard.ForecastButton"}}</button>
    {{/if}}
    <button type="button" data-action="openDetailSelection" data-tooltip="{{localize "GrimArithmetic.DangerBoard.DetailSelectionTooltip"}}">{{localize "GrimArithmetic.DangerBoard.DetailSelectionButton"}}</button>
    <button type="button" data-action="refresh" data-tooltip="{{localize "GrimArithmetic.DangerBoard.RefreshTooltip"}}">{{localize "GrimArithmetic.DangerBoard.RefreshButton"}}</button>
  </div>

  <section class="grim-arithmetic-panel__danger-board">
    {{#if dangerBoard.skipped}}
      <p class="grim-arithmetic-panel__danger-board-empty">
        {{localize "GrimArithmetic.DangerBoard.TooLarge"}}
      </p>
    {{else if dangerBoard.empty}}
      <p class="grim-arithmetic-panel__danger-board-empty">
        {{localize "GrimArithmetic.DangerBoard.Empty"}}
      </p>
    {{else}}
      <h3 class="grim-arithmetic-panel__section-title" data-tooltip="{{localize "GrimArithmetic.DangerBoard.EndangeredTooltip"}}">{{localize "GrimArithmetic.DangerBoard.EndangeredTitle"}}</h3>
      <ol class="grim-arithmetic-panel__danger-grid">
        {{#each dangerBoard.topEndangeredPcs}}
          <li class="grim-arithmetic-panel__danger-row">
            <span class="grim-arithmetic-panel__danger-row-rank" aria-hidden="true"></span>
            <span class="grim-arithmetic-panel__danger-row-label">
              <strong>{{pcName}}</strong>
              <span class="grim-arithmetic-panel__danger-row-vs">{{localize "GrimArithmetic.Common.Vs"}}</span>
              {{enemyName}} <em>{{attackName}}</em>
            </span>
            <span class="grim-arithmetic-panel__danger-row-percent" data-tooltip="{{localize "GrimArithmetic.Common.DownTooltip"}}">{{downPercent}}%</span>
            <span class="grim-arithmetic-panel__risk-pill grim-arithmetic-panel__risk-pill--{{riskClass}}" data-tooltip="{{localize "GrimArithmetic.Common.RiskPillTooltip"}}">{{riskLabel}}</span>
            <button type="button"
                    class="grim-arithmetic-panel__danger-row-action"
                    data-action="openDetailPair"
                    data-grim-pc-id="{{pcId}}"
                    data-grim-enemy-id="{{enemyId}}"
                    data-grim-attack-id="{{attackId}}">{{localize "GrimArithmetic.Common.Detail"}}</button>
          </li>
        {{/each}}
      </ol>

      <h3 class="grim-arithmetic-panel__section-title" data-tooltip="{{localize "GrimArithmetic.DangerBoard.DangerousTooltip"}}">{{localize "GrimArithmetic.DangerBoard.DangerousTitle"}}</h3>
      <ol class="grim-arithmetic-panel__danger-grid">
        {{#each dangerBoard.topDangerousEnemies}}
          <li class="grim-arithmetic-panel__danger-row">
            <span class="grim-arithmetic-panel__danger-row-rank" aria-hidden="true"></span>
            <span class="grim-arithmetic-panel__danger-row-label">
              <strong>{{enemyName}}</strong> <em>{{attackName}}</em>
              <span class="grim-arithmetic-panel__danger-row-vs">{{localize "GrimArithmetic.Common.Vs"}}</span>
              {{pcName}}
            </span>
            <span class="grim-arithmetic-panel__danger-row-percent" data-tooltip="{{localize "GrimArithmetic.Common.DownTooltip"}}">{{downPercent}}%</span>
            <span class="grim-arithmetic-panel__risk-pill grim-arithmetic-panel__risk-pill--{{riskClass}}" data-tooltip="{{localize "GrimArithmetic.Common.RiskPillTooltip"}}">{{riskLabel}}</span>
            <button type="button"
                    class="grim-arithmetic-panel__danger-row-action"
                    data-action="openDetailPair"
                    data-grim-pc-id="{{pcId}}"
                    data-grim-enemy-id="{{enemyId}}"
                    data-grim-attack-id="{{attackId}}">{{localize "GrimArithmetic.Common.Detail"}}</button>
          </li>
        {{/each}}
      </ol>
    {{/if}}

    {{#if dangerBoard.caveats.length}}
      <ul class="grim-arithmetic-panel__danger-caveats">
        {{#each dangerBoard.caveats}}
          <li>{{this}}</li>
        {{/each}}
      </ul>
    {{/if}}
  </section>
</section>
